[Unit]
Description=Capsule Dragon Radar Dashboard (gunicorn)
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory={{ app_root }}
Environment=PYTHONUNBUFFERED=1
ExecStart={{ venv_path }}/bin/gunicorn --workers 2 --bind 127.0.0.1:8000 wsgi:app
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
